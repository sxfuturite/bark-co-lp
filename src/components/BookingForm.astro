---
---
<section id="booking" class="py-5" style="background-color: var(--white); margin-top: -60px; position: relative; z-index: 10;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="card border-0 shadow-lg" style="border-radius: 1.5rem; overflow: hidden;">
                    <div class="card-body p-4 p-md-5 bg-white">
                        <h3 class="text-center fw-bold mb-4" style="color: var(--primary-color); font-size: 2.5rem;">Planea su estancia ideal</h3>
                        <form id="realBookingForm" class="booking-form">
                            <input type="hidden" name="servicio" value="Hospedaje">

                            <!-- Sección 1: Fechas -->
                            <div class="row mb-4 pb-2 border-bottom">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label for="fecha-entrada" class="form-label fw-semibold" style="color: var(--secondary-color);">1. Fecha de entrada</label>
                                    <input type="date" class="form-control rounded-pill px-4 py-2 bg-light border-0" id="fecha-entrada" name="fecha_entrada">
                                </div>
                                <div class="col-md-6">
                                    <label for="fecha-salida" class="form-label fw-semibold" style="color: var(--secondary-color);">Fecha de salida</label>
                                    <input type="date" class="form-control rounded-pill px-4 py-2 bg-light border-0" id="fecha-salida" name="fecha_salida">
                                </div>
                            </div>

                            <!-- Sección 2: Datos de Contacto -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold mb-3" style="color: var(--secondary-color);">2. Tus datos de contacto</label>
                                <div class="row g-3">
                                    <div class="col-md-12 mb-2">
                                        <input type="text" class="form-control rounded-pill px-4 py-3 bg-light border-0" placeholder="Nombre completo" name="nombre" required>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="tel" class="form-control rounded-pill px-4 py-3 bg-light border-0" placeholder="Teléfono" name="telefono" required>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="email" class="form-control rounded-pill px-4 py-3 bg-light border-0" placeholder="Correo electrónico" name="correo" required>
                                    </div>
                                </div>
                            </div>

                            <!-- Botón de acción -->
                            <div class="text-center mt-5">
                                <button type="submit" class="btn btn-accent-green btn-lg px-5 py-3 w-100 fs-5 fw-bold shadow-sm">Quiero apartar mi lugar</button>
                                <p class="text-center text-muted small mt-3 mb-0">Te contactaremos por WhatsApp en menos de 24 horas para coordinar los detalles.</p>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('realBookingForm');
        console.log("Script de reserva cargado. Formulario:", form);
        
        if (form) {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());
                
                // Validación básica de fechas
                if (!data.fecha_entrada || !data.fecha_salida) {
                    alert('Por favor, indica las fechas de entrada y salida para apartar tu lugar.');
                    return;
                }
                
                if (new Date(data.fecha_salida) < new Date(data.fecha_entrada)) {
                    alert('La fecha de salida no puede ser anterior a la de entrada.');
                    return;
                }
                
                data.origen = "https://bark-co-lp.vercel.app/";
                
                const btn = form.querySelector('button[type="submit"]');
                const originalText = btn ? btn.textContent : 'Quiero apartar mi lugar';
                
                if (btn) {
                    btn.textContent = 'Enviando...';
                    btn.disabled = true;
                }

                try {
                    console.log("Datos a enviar (Reserva):", data);
                    const response = await fetch('https://n8n.ongoing.mx/webhook/2dd3eed3-0f4f-41a3-a861-66d2e8265e97', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'barkco': 'Huo0lpaw.'
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        alert('¡Solicitud enviada con éxito! Nos comunicaremos contigo pronto para coordinar los detalles.');
                        form.reset();
                    } else {
                        alert('Hubo un error al enviar tu solicitud. Código: ' + response.status);
                    }
                } catch (error) {
                    console.error('Error en fetch:', error);
                    alert('Error de conexión al enviar. Revisa la consola para más detalles: ' + error.message);
                } finally {
                    if (btn) {
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }
                }
            });
        }
    });
</script>
