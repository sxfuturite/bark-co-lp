---
---
<section id="tarifas" class="py-5" style="background-color: var(--white); border-bottom: 1px solid rgba(156, 132, 94, 0.15);">
    <div class="container py-4">
        <h2 class="text-center mb-4 font-decorative text-gradient" style="font-size: 2.8rem;">Tarifas y Cotización</h2>
        <p class="lead text-center mb-5 mx-auto" style="max-width: 650px; color: var(--primary-color);">
            Brindamos una experiencia premium y adaptada a cada perrito. Nuestras tarifas se personalizan según su tamaño, temperamento y necesidades de cuidado.
        </p>

        <div class="row g-4 g-lg-5 mb-5 justify-content-center">
            <!-- Hospedaje -->
            <div class="col-md-4">
                <div class="card h-100 pricing-card">
                    <div class="text-center pt-4 pb-2">
                        <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1rem;">HOTEL CANINO</span>
                        <h4 class="fw-bold mt-1 mb-0" style="color: var(--primary-color); font-size: 1.4rem;">Hospedaje</h4>
                    </div>
                    
                    <!-- Ribbon -->
                    <div class="ribbon-wrapper">
                        <div class="pricing-ribbon ribbon-blue">
                            <span class="price-period">desde</span>
                            <span class="price-number">$750</span>
                            <span class="price-period">MXN / noche</span>
                        </div>
                        <div class="ribbon-fold fold-blue"></div>
                    </div>
                    
                    <div class="card-body px-4 py-2 d-flex flex-column justify-content-between">
                        <div>
                            <ul class="list-unstyled text-start mb-4">
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Suites individuales climatizadas (sin jaulas)</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Supervisión profesional 24/7 Fear Free</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Actividades y paseos recreativos diarios</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Cámaras en vivo para ver a tu perrito</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-x-circle-fill text-danger me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16" style="opacity: 0.6;">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                                    </svg>
                                    <span class="text-muted">Grooming & Estética (Costo adicional)</span>
                                </li>
                            </ul>
                        </div>
                        <div class="text-center pt-2 pb-3">
                            <a href="#booking" class="btn btn-pricing-blue rounded-pill px-4 py-2 fw-bold w-100">Quiero apartar Hospedaje</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guardería -->
            <div class="col-md-4">
                <div class="card h-100 pricing-card">
                    <div class="text-center pt-4 pb-2">
                        <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1rem;">DAY CARE</span>
                        <h4 class="fw-bold mt-1 mb-0" style="color: var(--primary-color); font-size: 1.4rem;">Guardería</h4>
                    </div>
                    
                    <!-- Ribbon -->
                    <div class="ribbon-wrapper">
                        <div class="pricing-ribbon ribbon-green">
                            <span class="price-period">desde</span>
                            <span class="price-number">$450</span>
                            <span class="price-period">MXN / día</span>
                        </div>
                        <div class="ribbon-fold fold-green"></div>
                    </div>
                    
                    <div class="card-body px-4 py-2 d-flex flex-column justify-content-between">
                        <div>
                            <ul class="list-unstyled text-start mb-4">
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Socialización Fear Free controlada</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Áreas de juego interiores y exteriores</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Reportes de bienestar diarios</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-x-circle-fill text-danger me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16" style="opacity: 0.6;">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                                    </svg>
                                    <span class="text-muted">Habitación privada para dormir</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-x-circle-fill text-danger me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16" style="opacity: 0.6;">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                                    </svg>
                                    <span class="text-muted">Grooming & Estética (Costo adicional)</span>
                                </li>
                            </ul>
                        </div>
                        <div class="text-center pt-2 pb-3">
                            <a href="#booking" class="btn btn-pricing-green rounded-pill px-4 py-2 fw-bold w-100">Quiero apartar Guardería</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Grooming & Spa -->
            <div class="col-md-4">
                <div class="card h-100 pricing-card">
                    <div class="text-center pt-4 pb-2">
                        <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1rem;">ESTÉTICA Y SPA</span>
                        <h4 class="fw-bold mt-1 mb-0" style="color: var(--primary-color); font-size: 1.4rem;">Grooming & Spa</h4>
                    </div>
                    
                    <!-- Ribbon -->
                    <div class="ribbon-wrapper">
                        <div class="pricing-ribbon ribbon-bronze">
                            <span class="price-period">desde</span>
                            <span class="price-number">$350</span>
                            <span class="price-period">MXN / servicio</span>
                        </div>
                        <div class="ribbon-fold fold-bronze"></div>
                    </div>
                    
                    <div class="card-body px-4 py-2 d-flex flex-column justify-content-between">
                        <div>
                            <ul class="list-unstyled text-start mb-4">
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Baño y corte con secado silencioso Fear Free</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Productos dermatológicos premium</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill text-success me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                    </svg>
                                    <span>Aromaterapia y música relajante</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-x-circle-fill text-danger me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16" style="opacity: 0.6;">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                                    </svg>
                                    <span class="text-muted">Estancia de día completo (Costo adicional)</span>
                                </li>
                                <li class="mb-3 d-flex align-items-start">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-x-circle-fill text-danger me-2 flex-shrink-0 mt-1" viewBox="0 0 16 16" style="opacity: 0.6;">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                                    </svg>
                                    <span class="text-muted">Cámaras en vivo (Costo adicional)</span>
                                </li>
                            </ul>
                        </div>
                        <div class="text-center pt-2 pb-3">
                            <a href="#booking" class="btn btn-pricing-bronze rounded-pill px-4 py-2 fw-bold w-100">Quiero apartar Spa</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banner de Cotización -->
        <div class="p-4 p-md-5 rounded-4 text-center shadow-sm mt-4 mx-auto" style="max-width: 800px; background-color: var(--bg-brand); border: 1px solid rgba(156, 132, 94, 0.15);">
            <h4 class="fw-bold mb-3" style="color: var(--primary-color);">¿Quieres saber el costo para tu perro?</h4>
            <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
                Como cada mascota es única, diseñamos un presupuesto especial en segundos. Cuéntanos un poco sobre él y te enviaremos una cotización detallada.
            </p>
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <a href="#booking" class="btn btn-accent-green px-4 py-3 fw-bold shadow-sm">
                    Quiero una cotización a la medida
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .pricing-card {
        position: relative;
        background-color: var(--white);
        border: 1px solid rgba(156, 132, 94, 0.15) !important;
        border-radius: 1.5rem;
        overflow: visible !important; /* Required to let the 3D ribbon protrude */
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .pricing-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(156, 132, 94, 0.12);
    }
    
    @media (max-width: 575.98px) {
        .pricing-card {
            margin-left: 12px;
            margin-right: 12px;
        }
    }
    
    .ribbon-wrapper {
        position: relative;
        margin-left: -21px; /* Overlap left edge */
        margin-right: 0;
        margin-bottom: 1.5rem;
    }
    
    .pricing-ribbon {
        position: relative;
        color: white;
        padding: 12px 20px;
        font-weight: bold;
        font-size: 1.1rem;
        display: flex;
        align-items: baseline;
        justify-content: center;
        flex-wrap: wrap;
        box-shadow: 2px 4px 8px rgba(0, 0, 0, 0.1);
        border-radius: 0 8px 8px 0;
        clip-path: polygon(0 0, 100% 0, 95% 100%, 0 100%);
    }
    
    .ribbon-blue {
        background: linear-gradient(135deg, #4869A3, #334d7a);
    }
    
    .ribbon-green {
        background: linear-gradient(135deg, #4D967C, #356b57);
    }
    
    .ribbon-bronze {
        background: linear-gradient(135deg, #B89F74, #9C845E);
    }
    
    .ribbon-fold {
        position: absolute;
        left: 0;
        bottom: -10px;
        width: 0;
        height: 0;
        border-right: 10px solid transparent;
        border-left: 10px solid transparent;
        z-index: -1;
    }
    
    .fold-blue {
        border-top: 10px solid #283d61;
    }
    
    .fold-green {
        border-top: 10px solid #23473a;
    }
    
    .fold-bronze {
        border-top: 10px solid #6b5535;
    }
    
    .price-number {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
        margin: 0 6px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .price-period {
        font-size: 0.85rem;
        opacity: 0.9;
        font-weight: 500;
    }

    .btn-pricing-blue {
        background-color: #4869A3;
        color: white;
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }
    .btn-pricing-blue:hover {
        background-color: #334d7a;
        color: white;
        transform: translateY(-2px);
    }
    
    .btn-pricing-green {
        background-color: #4D967C;
        color: white;
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }
    .btn-pricing-green:hover {
        background-color: #356b57;
        color: white;
        transform: translateY(-2px);
    }
    
    .btn-pricing-bronze {
        background-color: #9C845E;
        color: white;
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }
    .btn-pricing-bronze:hover {
        background-color: #7c6849;
        color: white;
        transform: translateY(-2px);
    }
</style>
