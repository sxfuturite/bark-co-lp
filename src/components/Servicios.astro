---
---
<section id="servicios" class="py-5 bg-white">
    <div class="container py-4">
        <h2 class="text-center fw-bold mb-5 font-decorative text-gradient" style="font-size: 2.8rem;">Todo lo que tu mejor amigo necesita</h2>
        
        <div class="row g-4 mb-5">
            <!-- Hospedaje -->
            <div class="col-md-4">
                <div class="card h-100 border-0 glass-card" style="border-radius: 1rem;">
                    <div class="card-body p-4 p-xl-5">
                        <div class="mb-4 text-center">
                            <div class="service-icon-container rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: var(--accent-blue); color: white;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-moon-stars-fill" viewBox="0 0 16 16">
                                  <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278"/>
                                  <path d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.734 1.734 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162A1.734 1.734 0 0 0 9.31 6.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.734 1.734 0 0 0 1.097-1.097zM13.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732l-.774-.258a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z"/>
                                </svg>
                            </div>
                            <h3 class="card-title fw-bold" style="color: var(--primary-color);">Hospedaje</h3>
                        </div>
                        <p class="card-text text-muted mb-4 text-center">Habitaciones boutique diseñadas para el descanso y tranquilidad de tu perro.</p>
                        <ul class="list-unstyled fw-medium text-secondary">
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-blue);">✓</span> Habitaciones climatizadas</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-blue);">✓</span> Camas ortopédicas premium</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-blue);">✓</span> Aromaterapia relajante</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-blue);">✓</span> Monitoreo y reporte diario</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-blue);">✓</span> Rutina personalizada</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Guardería -->
            <div class="col-md-4">
                <div class="card h-100 border-0 glass-card" style="border-radius: 1rem;">
                    <div class="card-body p-4 p-xl-5">
                        <div class="mb-4 text-center">
                            <div class="service-icon-container rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: var(--secondary-color); color: white;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-brightness-high-fill" viewBox="0 0 16 16">
                                  <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6m0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
                                </svg>
                            </div>
                            <h3 class="card-title fw-bold" style="color: var(--primary-color);">Guardería</h3>
                        </div>
                        <p class="card-text text-muted mb-4 text-center">Un espacio seguro y divertido para socializar mientras tú trabajas.</p>
                        <ul class="list-unstyled fw-medium text-secondary">
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--secondary-color);">✓</span> Grupos reducidos por tamaño</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--secondary-color);">✓</span> Supervisión profesional 100%</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--secondary-color);">✓</span> Actividades de enriquecimiento</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--secondary-color);">✓</span> Áreas interiores y exteriores</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--secondary-color);">✓</span> Tiempo estructurado de siesta</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Paseo -->
            <div class="col-md-4">
                <div class="card h-100 border-0 glass-card" style="border-radius: 1rem;">
                    <div class="card-body p-4 p-xl-5">
                        <div class="mb-4 text-center">
                            <div class="service-icon-container rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: var(--accent-green); color: white;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-tree-fill" viewBox="0 0 16 16">
                                  <path d="M8.416.223a.5.5 0 0 0-.832 0l-3 4.5A.5.5 0 0 0 5 5.5h.098L3.076 8.739A.5.5 0 0 0 3.5 9.5h.191l-1.638 3.276a.5.5 0 0 0 .447.724H7V16h2v-2.5h4.5a.5.5 0 0 0 .447-.724L12.31 9.5h.191a.5.5 0 0 0 .424-.761L10.902 5.5H11a.5.5 0 0 0 .416-.777z"/>
                                </svg>
                            </div>
                            <h3 class="card-title fw-bold" style="color: var(--primary-color);">Paseo</h3>
                        </div>
                        <p class="card-text text-muted mb-4 text-center">Ejercicio físico y mental esencial para el equilibrio de tu mascota.</p>
                        <ul class="list-unstyled fw-medium text-secondary">
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-green);">✓</span> Paseos personalizados</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-green);">✓</span> Rutas seguras en San Pedro</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-green);">✓</span> Refuerzo positivo constante</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-green);">✓</span> Hidratación adecuada</li>
                            <li class="mb-2 d-flex"><span class="me-3 fw-bold" style="color: var(--accent-green);">✓</span> Reporte GPS de ruta</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-3">
            <a href="#booking" class="btn btn-secondary btn-lg px-5 py-3 fs-5 shadow-sm">Reserva tu servicio</a>
        </div>
    </div>
</section>
