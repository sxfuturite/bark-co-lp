---
const currentYear = new Date().getFullYear();
---
<footer id="contacto" class="pt-5 pb-4" style="background-color: var(--primary-color); color: var(--bg-brand);">
    <div class="container pt-4">
        <div class="row gx-lg-5 mb-5 align-items-center">
            <!-- Columna Izquierda: Logo y Redes -->
            <div class="col-lg-6 mb-4 mb-lg-0 text-center text-lg-start">
                <img src="/assets/img/logo_light_01.png" alt="Bark & Co." style="height: 70px; width: auto;" class="mb-3">
                <p class="mb-4" style="color: rgba(242, 235, 229, 0.7); max-width: 400px; line-height: 1.6;">
                    El primer Centro de Bienestar Canino Fear Free en San Pedro. Creamos un espacio diseñado para la felicidad y tranquilidad de tu perro.
                </p>
                <div class="d-flex justify-content-center justify-content-lg-start gap-4 mt-3">
                    <a href="#" class="text-white text-decoration-none" aria-label="Instagram" style="opacity: 0.8; transition: opacity 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-instagram" viewBox="0 0 16 16">
                            <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
                        </svg>
                    </a>
                    <a href="#" class="text-white text-decoration-none" aria-label="Facebook" style="opacity: 0.8; transition: opacity 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                            <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Columna Derecha: Newsletter / Lista de Espera -->
            <div class="col-lg-5 offset-lg-1 mt-4 mt-lg-0">
                <div class="p-4 rounded-4" style="background-color: rgba(242, 235, 229, 0.05); border: 1px solid rgba(242, 235, 229, 0.15);">
                    <h5 class="fw-bold mb-2 text-white">¿Aún no estás listo para reservar?</h5>
                    <p class="small mb-3" style="color: rgba(242, 235, 229, 0.8);">
                        Únete a nuestra lista de interesados. Recibe noticias de nuestra apertura, promociones de lanzamiento y consejos Fear Free.
                    </p>
                    <form id="newsletterForm" class="d-flex flex-column flex-sm-row gap-2">
                        <input type="email" name="email" class="form-control rounded-pill px-3 py-2 bg-light border-0" placeholder="Tu correo electrónico" required style="font-size: 0.9rem;">
                        <button type="submit" class="btn btn-secondary rounded-pill px-4 py-2 fw-semibold" style="font-size: 0.9rem; white-space: nowrap;">
                            Unirme
                        </button>
                    </form>
                    <div id="newsletterSuccess" class="text-success small mt-2 d-none">
                        ¡Gracias! Te mantendremos informado sobre nuestras novedades.
                    </div>
                </div>
            </div>
        </div>

        <div class="w-100">
            <hr style="border-color: rgba(242, 235, 229, 0.2);">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3" style="color: rgba(242, 235, 229, 0.5); font-size: 0.85rem;">
                <p class="mb-2 mb-md-0">&copy; {currentYear} Bark & Co. Todos los derechos reservados.</p>
                <a href="#" class="text-decoration-none" style="color: rgba(242, 235, 229, 0.5); transition: color 0.3s;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='rgba(242, 235, 229, 0.5)'">Aviso de Privacidad</a>
            </div>
        </div>

        <script is:inline>
            document.addEventListener("DOMContentLoaded", function() {
                const nlForm = document.getElementById('newsletterForm');
                const nlSuccess = document.getElementById('newsletterSuccess');
                
                if (nlForm) {
                    nlForm.addEventListener('submit', async function(e) {
                        e.preventDefault();
                        const emailInput = nlForm.querySelector('input[name="email"]');
                        const btn = nlForm.querySelector('button[type="submit"]');
                        const email = emailInput ? emailInput.value : '';
                        
                        if (!email) return;
                        
                        const originalText = btn ? btn.textContent : 'Unirme';
                        if (btn) {
                            btn.textContent = 'Enviando...';
                            btn.disabled = true;
                        }
                        
                        const data = {
                            email: email,
                            origen: window.location.href,
                            tipo_registro: "Newsletter/Lista de espera"
                        };
                        
                        try {
                            const response = await fetch('https://n8n.ongoing.mx/webhook/2dd3eed3-0f4f-41a3-a861-66d2e8265e97', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'barkco': 'Huo0lpaw.'
                                },
                                body: JSON.stringify(data)
                            });
                            
                            if (response.ok) {
                                nlForm.reset();
                                if (nlSuccess) {
                                    nlSuccess.classList.remove('d-none');
                                    setTimeout(() => {
                                        nlSuccess.classList.add('d-none');
                                    }, 5000);
                                }
                            } else {
                                alert('Hubo un problema al registrar tu correo. Inténtalo de nuevo.');
                            }
                        } catch (error) {
                            console.error('Error:', error);
                            alert('Error de conexión. Revisa tu red.');
                        } finally {
                            if (btn) {
                                btn.textContent = originalText;
                                btn.disabled = false;
                            }
                        }
                    });
                }
            });
        </script>
    </div>
</footer>
