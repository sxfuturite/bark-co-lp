---
const currentYear = new Date().getFullYear();
---
<footer id="contacto" class="pt-5 pb-4" style="background-color: var(--primary-color); color: var(--bg-brand);">
    <div class="container pt-4">
        <div class="row gx-lg-5 mb-5">
            <!-- Lado Izquierdo: Formulario de Contacto -->
            <div class="col-lg-6 mb-5 mb-lg-0 pe-lg-5">
                <h2 class="fw-bold mb-4 font-decorative" style="color: var(--secondary-color); font-size: 2.5rem;">Hablemos</h2>
                <p class="mb-4" style="color: rgba(242, 235, 229, 0.8);">Déjanos tus datos y nos comunicaremos contigo para resolver cualquier duda o agendar una cita.</p>
                
                <form id="contactForm" class="minimal-form">
                    <div class="mb-4">
                        <input type="text" class="form-control bg-transparent text-white border-0 border-bottom rounded-0 px-0 py-2" placeholder="Nombre completo" name="nombre" required style="border-color: rgba(242, 235, 229, 0.3) !important;">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <input type="tel" class="form-control bg-transparent text-white border-0 border-bottom rounded-0 px-0 py-2" placeholder="Teléfono" name="telefono" required style="border-color: rgba(242, 235, 229, 0.3) !important;">
                        </div>
                        <div class="col-md-6 mb-4">
                            <input type="email" class="form-control bg-transparent text-white border-0 border-bottom rounded-0 px-0 py-2" placeholder="Correo electrónico" name="correo" required style="border-color: rgba(242, 235, 229, 0.3) !important;">
                        </div>
                    </div>
                    <div class="mb-5">
                        <textarea class="form-control bg-transparent text-white border-0 border-bottom rounded-0 px-0 py-2" rows="2" name="mensaje" placeholder="¿En qué podemos ayudarte?" style="border-color: rgba(242, 235, 229, 0.3) !important;"></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary px-5 py-3 rounded-pill fw-bold w-100 w-md-auto shadow-sm">Enviar Mensaje</button>
                </form>
            </div>

            <!-- Lado Derecho: Logo, Redes y Legales -->
            <div class="col-lg-6 ps-lg-5 d-flex flex-column justify-content-between">
                <div>
                    <img src="/assets/img/logo_light_01.png" alt="Bark & Co." style="height: 60px; width: auto;" class="mb-4">
                    <p style="color: rgba(242, 235, 229, 0.7); max-width: 400px; line-height: 1.8;">Experiencia Premium y Boutique para tu mejor amigo. Porque ellos también merecen lujo, cuidado y tranquilidad en cada momento de su vida.</p>
                    
                    <div class="d-flex gap-4 mt-4 mb-5">
                        <a href="#" class="text-white text-decoration-none" aria-label="Instagram" style="opacity: 0.8; transition: opacity 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-instagram" viewBox="0 0 16 16">
                                <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
                            </svg>
                        </a>
                        <a href="#" class="text-white text-decoration-none" aria-label="Facebook" style="opacity: 0.8; transition: opacity 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
                            </svg>
                        </a>
                    </div>
                </div>

                <div>
                    <hr style="border-color: rgba(242, 235, 229, 0.2);">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3" style="color: rgba(242, 235, 229, 0.5); font-size: 0.85rem;">
                        <p class="mb-2 mb-md-0">&copy; {currentYear} Bark & Co. Todos los derechos reservados.</p>
                        <a href="#" class="text-decoration-none" style="color: rgba(242, 235, 229, 0.5); transition: color 0.3s;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='rgba(242, 235, 229, 0.5)'">Aviso de Privacidad</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
        const form = document.getElementById('contactForm');
        console.log("Script de formulario cargado. Formulario:", form);
        
        if (form) {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                console.log("Enviando formulario...");
                
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());
                data.origen = "https://bark-co-lp.vercel.app/";
                
                const btn = form.querySelector('button[type="submit"]');
                const originalText = btn ? btn.textContent : 'Enviar Mensaje';
                
                if (btn) {
                    btn.textContent = 'Enviando...';
                    btn.disabled = true;
                }

                try {
                    console.log("Datos a enviar:", data);
                    const response = await fetch('https://n8n.ongoing.mx/webhook-test/2dd3eed3-0f4f-41a3-a861-66d2e8265e97', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'barkco': 'Huo0lpaw.'
                        },
                        body: JSON.stringify(data)
                    });

                    console.log("Respuesta del servidor:", response);

                    if (response.ok) {
                        alert('¡Mensaje enviado con éxito! Nos comunicaremos contigo pronto.');
                        form.reset();
                    } else {
                        alert('Hubo un error al enviar el mensaje. Código: ' + response.status);
                    }
                } catch (error) {
                    console.error('Error en fetch:', error);
                    alert('Error de conexión al enviar. Revisa la consola para más detalles: ' + error.message);
                } finally {
                    if (btn) {
                        btn.textContent = originalText;
                        btn.disabled = false;
                    }
                }
            });
        }
    });
</script>
