---
import { transform } from 'astro:schema'

const cards = [
    {
        isRawSvg: true,
        title: 'Suites, no jaulas',
        text: 'Usamos suites amplias con espacios propios y visualmente abiertos para un descanso real.',
        svgContent:
            '<svg version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 450.954 450.954" xml:space="preserve" class="w-100 h-100" fill="var(--white)"><g><g><path d="M51.617,223.95c-0.117-0.726-0.363-1.412-0.419-2.163c-0.576-7.901,2.765-19.261,20.132-30.044l-0.277-3.436c-0.688-8.731-0.774-19.278,0.861-29.808c-44.217,8.737-71.907,21.188-71.907,35.021C0.007,205.085,19.418,215.681,51.617,223.95z"/><path d="M363.613,204.674c2.392,1.32,6.749,3.202,13.365,4.172c10.958,1.612,19.073,6.472,24.644,14.482c30.793-8.186,49.332-18.527,49.332-29.815c0-16.268-38.272-30.628-96.725-39.271c0.325,1.328,0.655,2.607,0.954,4.02C360.866,185.54,362.893,198.616,363.613,204.674z"/><path d="M176.502,259.547c-0.411-37.435-57.18-34.14-75.682-35.792c-18.512-1.643-22.62-25.502-22.62-25.502c-36.607,19.741-16.456,41.535,6.172,49.771c22.617,8.231,47.715-1.645,64.985,11.116c17.275,12.751,14.812,32.072,14.812,32.072S176.911,296.972,176.502,259.547z"/><path d="M306.821,225.92c-0.563,12.614,13.01,19.688,21.719,22.917c3.839,1.422,6.997,5.479,6.9,9.567l-0.487,21.394c-0.086,4.093,2.687,9.13,6.53,10.526c5.23,1.904,13.868,4.22,27.035,5.52c15.95,1.56,25.745-6.169,30.772-12.02c2.661-3.103,3.687-9.358,3.174-13.421c-0.523-4.067-1.254-10.231-2.285-19.393c-2.463-22.227-11.918-30.036-25.908-32.093c-13.984-2.054-20.154-7.812-20.154-7.812s0-7.82-8.643-49.366c-8.633-41.541-30.849-39.895-30.849-39.895C316.276,137.896,307.644,207.409,306.821,225.92z"/><path d="M265.994,197.06c0.325-3.988-0.853-7.49-3.605-10.682c-10.607-12.283-39.918-14.812-42.611-15.018c-11.977,1.257-42.343,7.307-42.643,20.604c-0.19,8.516,4.486,18.7,12.212,26.583c7.259,7.424,16.13,11.7,24.332,11.7c0.467,0,0.932-0.016,1.391-0.036C233.16,229.165,263.821,223.478,265.994,197.06z"/><path d="M82.816,186.782l1.46,8.452c0.033,0.183,3.659,19.212,17.087,20.406c2.315,0.206,5.324,0.333,8.818,0.482c17.316,0.734,46.118,1.95,61.644,16.11c2.844-0.021,6.145-0.056,9.897-0.137c-0.023-1.925,0.063-3.921,0.262-5.957l0.183-1.96c-9.031-9.572-14.213-21.47-13.9