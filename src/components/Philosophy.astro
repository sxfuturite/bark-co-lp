    },
    {
        icon: 'tree-fill',
        title: 'Indoor Park climatizado',
        text: 'Juega, explora y libera energía todos los días — en un espacio seguro y climatizado, sin importar el clima de Monterrey (salida opcional a parques cercanos).',
        svgContent: '<path d="M8.416.223a.5.5 0 0 0-.832 0l-3 4.5A.5.5 0 0 0 5 5.5h.098L3.076 8.735A.5.5 0 0 0 3.5 9.5h.191l-1.638 3.276a.5.5 0 0 0 .447.724H7V15h2v-1.5h4.484a.5.5 0 0 0 .447-.724L12.31 9.5h.191a.5.5 0 0 0 .424-.765L10.902 5.5H11a.5.5 0 0 0 .416-.777z"></path>',
    },
    {
        icon: 'activity',
        title: 'Actividades estructuradas',
        text: 'Adaptadas a tu perro y diseñadas para estimular mente y cuerpo - no sólo para cansar.',
        svgContent: '<path fill-rule="evenodd" d="M6 2a.5.5 0 0 1 .47.33L10 12.036l1.53-4.22A.5.5 0 0 1 12 7.5h3.5a.5.5 0 0 1 0-1H12.36l-1.89 5.2a.5.5 0 0 1-.94 0L6 3.964L4.47 8.16A.5.5 0 0 1 4 8.5H.5a.5.5 0 0 1 0-1h3.14l1.89-5.2A.5.5 0 0 1 6 2"></path>',
    },
    {
        icon: 'shield-fill-plus',
        title: 'Supervisión profesional',
        text: 'Veterinario en sitio, staff entrenado en nuestro protocolo Stress & Fear Free y supervisión 24/7.',
        svgContent:
            '<path d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m-.5 5a.5.5 0 0 1 1 0v1.5H10a.5.5 0 0 1 0 1H8.5V9a.5.5 0 0 1-1 0V7.5H6a.5.5 0 0 1 0-1h1.5z"></path>',
    },
    {
        icon: 'moon-stars-fill',
        title: 'Ambiente de calma',
        text: 'Iluminación cálida, música ambiental, aromas suaves y rutinas predecibles.',
        svgContent:
            '<path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278"></path><path d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.734 1.734 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162A1.734 1.734 0 0 0 9.31 6.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.734 1.734 0 0 0 1.097-1.097zM13.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732l-.774-.258a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z"></path>',
    },
    {
        icon: 'camera-video-fill',
        title: 'Acceso y comunicación constante',
        text: 'Reporte diario, Webcam en áreas comunes y Webcam opcional en habitación.',
        svgContent: '<path fill-rule="evenodd" d="M0 5a2 2 0 0 1 2-2h7.5a2 2 0 0 1 1.983 1.738l3.11-1.382A1 1 0 0 1 16 4.269v7.462a1 1 0 0 1-1.406.913l-3.111-1.382A2 2 0 0 1 9.5 13H2a2 2 0 0 1-2-2z"/>',
    },
]
---

<section id="filosofia" class="py-5">
    <div class="container">
        <!-- Centered Main Title -->
        <div class="text-center">
            <h2 class="section-title text-center mb-4">Nuestra filosofía Stress & Fear Free</h2>
            <h3 class="h3 fw-bold mb-5" style="color: var(--primary-color);">Un compromiso con su bienestar emocional</h3>
        </div>

        <!-- Main Philosophy Block -->
        <div class="row align-items-center" style="padding-bottom: 25px;">
            <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
                <img src="/assets/img/perrito_pasto_1.webp" alt="Cuidado compasivo en Bark & Co." class="img-fluid rounded-4 shadow w-100" style="object-fit: cover; aspect-ratio: 4 / 3; object-position: left;" />
            </div>
            <div class="col-lg-6 px-4 px-lg-5 philosophy-text">
                <!-- Content Paragraphs -->
                <p class="mb-3 lead" style="color: var(--primary-color); line-height: 1.8; text-wrap: pretty;">
                    <strong>Bark & Co.</strong> es el Dog Wellness Club donde no sólo cuidamos a tu perro; lo hacemos crecer. Con nosotros tu perro se desarrolla en cuerpo, mente y emoción, y tú perteneces a una comunidad que te hace la vida más fácil y la llena de experiencias inolvidables.
                </p>
                <p class="mb-3 lead" style="color: var(--primary-color); line-height: 1.8; text-wrap: pretty;">En Bark & Co. creemos que un perro feliz también necesita sentirse seguro, tranquilo y emocionalmente cuidado.</p>
                <p class="mb-3 lead" style="color: var(--primary-color); line-height: 1.8; text-wrap: pretty;">Por eso, cada detalle de nuestra experiencia — desde cómo interactuamos con tu perro hasta cómo diseñamos nuestros espacios — está pensado para reducir el estrés y la ansiedad.</p>
            </div>
        </div>
    </div>
</section>

<!-- How we achieve it Section -->
<section id="filosofia-accion" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title text-center mb-4">Filosofía en acción</h2>
            <p class="section-subtitle mx-auto text-center px-4 px-md-0" style="max-width: 700px;">Porque el verdadero cuidado no solo protege su salud física. También protege su tranquilidad emocional.</p>
        </div>

        <div class="philosophy-marquee-container">
            <!-- Navigation Arrows -->
            <button type="button" class="carousel-control-btn prev-btn shadow-sm" aria-label="Deslizar izquierda">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"></path>
                </svg>
            </button>
            <button type="button" class="carousel-control-btn next-btn shadow-sm" aria-label="Deslizar derecha">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"></path>
                </svg>
            </button>

            <div class="philosophy-marquee-track-wrapper" id="marquee-wrapper">
                <div class="philosophy-marquee-track">
                    <!-- Tarjetas de Filosofía (Únicas) -->
                    {
                        cards.map((card) => (
                            <div class="philosophy-marquee-item">
                                <div class="card h-100 border-0 glass-card p-4 text-center" style="border-radius: 1.5rem;">
                                    <div
                                        class="mb-4 d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm mx-auto animate-hover"
                                        style="width: 70px; height: 70px; background: linear-gradient(135deg, var(--secondary-color) 0%, #857050 100%); color: var(--white); transition: transform 0.3s ease;"
                                    >
                                        {card.isRawSvg ? (
                                            <div class="d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" set:html={card.svgContent} />
                                        ) : (
                                            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class={`bi bi-${card.icon}`} viewBox="0 0 16 16" set:html={card.svgContent} />
                                        )}
                                    </div>
                                    <h4 class="fw-bold mb-3" style="color: var(--primary-color); font-size: 1.3rem;">
                                        {card.title}
                                    </h4>
                                    <p class="text-muted mb-0 px-2" style="font-size: 0.95rem; line-height: 1.6;">
                                        {card.text}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @media (max-width: 991px) {
        .philosophy-text p {
            font-size: 1rem !important;
        }
    }

    .philosophy-marquee-item .card {
        position: relative;
        overflow: hidden !important;
        padding: 1.5rem 1rem !important;
    }

    .philosophy-marquee-item h4 {
        font-size: 1.1rem !important;
    }

    .philosophy-marquee-item p {
        font-size: 0.88rem !important;
        line-height: 1.5 !important;
    }

    .philosophy-marquee-item .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url('/assets/img/bg_perritos.png');
        background-size: 500px; /* Zoom out */
        background-repeat: repeat;
        background-position: center;
        opacity: 0.1; /* Reducir opacidad */
        filter: blur(0.2px); /* Agregar blur */
        z-index: -1;
    }

    .philosophy-marquee-container {
        position: relative;
        width: 100%;
    }

    .philosophy-marquee-track-wrapper {
        overflow-x: auto;
        width: 100%;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        /* Hide scrollbar */
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding-top: 25px;
        padding-bottom: 25px;
    }

    .philosophy-marquee-track-wrapper::-webkit-scrollbar {
        display: none;
    }

    :global(.carousel-control-btn) {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(156, 132, 94, 0.25);
        color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0;
    }

    :global(.carousel-control-btn:hover) {
        background: var(--secondary-color);
        color: var(--white);
        border-color: var(--secondary-color);
        transform: translateY(-50%) scale(1.1);
    }

    :global(.carousel-control-btn.prev-btn) {
        left: -15px;
    }

    :global(.carousel-control-btn.next-btn) {
        right: -15px;
    }

    @media (max-width: 1200px) {
        :global(.carousel-control-btn.prev-btn) {
            left: 10px;
        }
        :global(.carousel-control-btn.next-btn) {
            right: 10px;
        }
    }

    @media (max-width: 576px) {
        :global(.carousel-control-btn) {
            width: 36px;
            height: 36px;
        }
        :global(.carousel-control-btn.prev-btn) {
            left: 5px;
        }
        :global(.carousel-control-btn.next-btn) {
            right: 5px;
        }
    }

    .philosophy-marquee-container::before,
    .philosophy-marquee-container::after {
        content: '';
        position: absolute;
        top: 0;
        width: 80px;
        height: 100%;
        z-index: 2;
        pointer-events: none;
    }

    .philosophy-marquee-container::before {
        left: 0;
        background: linear-gradient(to right, var(--bg-brand) 0%, rgba(242, 235, 229, 0) 100%);
    }

    .philosophy-marquee-container::after {
        right: 0;
        background: linear-gradient(to left, var(--bg-brand) 0%, rgba(242, 235, 229, 0) 100%);
    }

    .philosophy-marquee-track {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        width: max-content;
    }

    .philosophy-marquee-item {
        flex: 0 0 280px !important;
        width: 280px !important;
        flex-shrink: 0 !important;
        margin: 0 12px;
    }

    .philosophy-subtitle {
        font-size: 2.2rem;
    }

    @media (min-width: 768px) {
        .philosophy-subtitle {
            font-size: 2.8rem;
        }
    }

    @media (min-width: 992px) {
        .philosophy-subtitle {
            font-size: 3.2rem;
        }
    }
</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const wrapper = document.getElementById('marquee-wrapper')
        if (!wrapper) return

        const prevBtn = document.querySelector('.carousel-control-btn.prev-btn')
        const nextBtn = document.querySelector('.carousel-control-btn.next-btn')

        if (prevBtn && nextBtn) {
            prevBtn.addEventListener('click', () => {
                const scrollLeft = wrapper.scrollLeft
                // Si está en el inicio (o muy cerca), va al final
                if (scrollLeft <= 10) {
                    const maxScroll = wrapper.scrollWidth - wrapper.clientWidth
                    wrapper.scrollTo({ left: maxScroll, behavior: 'smooth' })
                } else {
                    wrapper.scrollBy({ left: -304, behavior: 'smooth' })
                }
            })

            nextBtn.addEventListener('click', () => {
                const scrollLeft = wrapper.scrollLeft
                const maxScroll = wrapper.scrollWidth - wrapper.clientWidth
                // Si está en el extremo final (o muy cerca), regresa al inicio
                if (scrollLeft >= maxScroll - 10) {
                    wrapper.scrollTo({ left: 0, behavior: 'smooth' })
                } else {
                    wrapper.scrollBy({ left: 304, behavior: 'smooth' })
                }
            })
        }
    })
</script>
