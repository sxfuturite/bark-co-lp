<style>
    .philosophy-marquee-container {
        overflow: hidden;
        width: 100%;
        position: relative;
        padding: 20px 0;
    }
    
    .philosophy-marquee-container::before,
    .philosophy-marquee-container::after {
        content: "";
        position: absolute;
        top: 0;
        width: 80px;
        height: 100%;
        z-index: 2;
        pointer-events: none;
    }
    
    .philosophy-marquee-container::before {
        left: 0;
        background: linear-gradient(to right, var(--bg-brand) 0%, rgba(242, 235, 229, 0) 100%);
    }
    
    .philosophy-marquee-container::after {
        right: 0;
        background: linear-gradient(to left, var(--bg-brand) 0%, rgba(242, 235, 229, 0) 100%);
    }
    
    .philosophy-marquee-track {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        width: max-content;
        animation: scrollMarquee 28s linear infinite;
    }
    
    .philosophy-marquee-track:hover {
        animation-play-state: paused;
    }
    
    .philosophy-marquee-item {
        flex: 0 0 320px !important;
        width: 320px !important;
        flex-shrink: 0 !important;
        margin: 0 15px;
    }
    
    @keyframes scrollMarquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .philosophy-title {
        font-size: 2.4rem;
    }
    .philosophy-subtitle {
        font-size: 2.2rem;
    }

    @media (min-width: 768px) {
        .philosophy-title {
            font-size: 3.2rem;
        }
        .philosophy-subtitle {
            font-size: 2.8rem;
        }
    }

    @media (min-width: 992px) {
        .philosophy-title {
            font-size: 3.8rem;
        }
        .philosophy-subtitle {
            font-size: 3.2rem;
        }
    }
</style>
